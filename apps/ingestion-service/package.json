{
  "name": "@rtsp/ingestion-service",
  "version": "0.1.0",
  "private": true,
  "description": "Ingestion Service - MQTT to Kafka",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "bun --watch src/main.ts",
    "start": "node dist/main.js",
    "start:dev": "bun run src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "echo 'No lint configured'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@rtsp/domain": "workspace:*",
    "@rtsp/application": "workspace:*",
    "@rtsp/infrastructure": "workspace:*",
    "@rtsp/shared": "workspace:*",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}